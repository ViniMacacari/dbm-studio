{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": [
    "src/app-config.ts",
    "src/core/**/*.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
