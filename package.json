{
  "name": "dbm-studio",
  "version": "0.2.0",
  "private": true,
  "description": "DBM Studio database editor built with Electron and TypeScript.",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "ng build dbmaster-renderer",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && ng build dbmaster-renderer --configuration development",
    "start": "node scripts/run-electron.mjs",
    "dev": "npm run build && node scripts/run-electron.mjs",
    "dist": "npm run build && electron-builder",
    "test": "tsx ./src/tests/test.ts"
  },
  "dependencies": {
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "fast-xml-parser": "^5.8.0",
    "fifadate": "^0.0.9",
    "fifarating": "^0.2.4",
    "node-cache": "^5.1.2",
    "rxjs": "^7.8.2",
    "transfermarkt-parser": "^0.1.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.3.25",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.19.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.dbm.studio",
    "productName": "DBM Studio",
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "app.ico",
        "to": "app.ico"
      }
    ],
    "win": {
      "icon": "app.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
