{
  "name": "dbmaster-electron-ts",
  "version": "0.1.0",
  "private": true,
  "description": "DB Master rewritten as an Electron and TypeScript desktop app.",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "ng build dbmaster-renderer",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && ng build dbmaster-renderer --configuration development",
    "start": "node scripts/run-electron.mjs",
    "dev": "npm run build && node scripts/run-electron.mjs",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "rxjs": "^7.8.2",
    "zone.js": "^0.15.1",
    "fast-xml-parser": "^5.8.0"
  },
  "devDependencies": {
    "@angular/build": "20.3.25",
    "@angular/cli": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@types/node": "^20.19.0",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.2",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.dbmaster.electron",
    "productName": "DB Master",
    "asar": false,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "app.ico",
        "to": "app.ico"
      }
    ],
    "win": {
      "icon": "app.ico",
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
